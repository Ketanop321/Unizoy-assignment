{
  "name": "unizoy-job-board",
  "version": "1.0.0",
  "description": "Unizoy Job Board monorepo",
  "scripts": {
    "dev": "npm run dev --workspaces --if-present --parallel",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "npm run prisma:generate -w apps/api",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:seed": "npm run prisma:seed -w apps/api"
  },
  "keywords": [
    "nextjs",
    "express",
    "prisma",
    "job-board"
  ],
  "author": "",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  }
}
